PORT=5000
NODE_ENV=development

# MongoDB URI used by the backend. MONGODB_URI is accepted as a fallback.
MONGO_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/atms?appName=Cluster0

# JWT Authentication
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS origin for the frontend
CLIENT_ORIGIN=http://localhost:5173
